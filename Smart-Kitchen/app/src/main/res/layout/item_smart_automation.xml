<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 规则展示界面 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_rule_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <!-- 规则名称 -->
                <TextView
                    android:id="@+id/tv_rule_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:text="高温防范"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/rule_type"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- 规则状态 -->
                <TextView
                    android:id="@+id/rule_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="执行中"
                    android:textColor="@color/state_success"
                    app:layout_constraintBottom_toBottomOf="@id/tv_rule_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_rule_name" />

                <!-- IF 条件 -->
                <LinearLayout
                    android:id="@+id/ll_condition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F0FDFA"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_rule_name">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="如果  "
                        android:textColor="#14B8A6"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/rule_condition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="环境温度 > 35°C"
                        android:textColor="#374151" />
                </LinearLayout>

                <!-- THEN 动作 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#F3F4F6"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/ll_condition">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="执行  "
                        android:textColor="#6B7280"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关闭烤箱 并 发送报警通知"
                        android:textColor="#374151" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 删除确认界面，覆盖在展示界面上 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_delete_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_delete_confirm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="确认删除"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#EF4444"
                    app:cornerRadius="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>