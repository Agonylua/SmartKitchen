<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="data"
            type="com.agonylua.smarthome.model.DeviceData" />

        <variable
            name="viewModel"
            type="com.agonylua.smarthome.viewModel.DeviceViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_timer_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/circle_bg"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:background="@drawable/bg_circle_outline_gray"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ProgressBar
                android:id="@+id/progress_timer"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="75"
                android:progressDrawable="@drawable/circle_progress_orange"
                android:rotation="-90"
                app:layout_constraintBottom_toBottomOf="@+id/circle_bg"
                app:layout_constraintEnd_toEndOf="@+id/circle_bg"
                app:layout_constraintStart_toStartOf="@+id/circle_bg"
                app:layout_constraintTop_toTopOf="@+id/circle_bg" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@+id/circle_bg"
                app:layout_constraintEnd_toEndOf="@+id/circle_bg"
                app:layout_constraintStart_toStartOf="@+id/circle_bg"
                app:layout_constraintTop_toTopOf="@+id/circle_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="加热时间"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_timer_big"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="01:30"
                    android:textColor="@color/text_primary"
                    android:textSize="56sp" />

                <TextView
                    android:id="@+id/tv_power_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="高火"
                    android:textColor="@color/secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_30s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+30s"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/secondary"
                app:cornerRadius="20dp"
                app:layout_constraintBottom_toBottomOf="@+id/circle_bg"
                app:layout_constraintEnd_toEndOf="@+id/circle_bg"
                app:layout_constraintStart_toStartOf="@+id/circle_bg"
                app:layout_constraintTop_toBottomOf="@+id/circle_bg" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_power"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_timer_display"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_heat_mode"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:width="1dp"
                android:checked="true"
                android:text="加热模式"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/secondary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_barbecue_mode"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="烧烤模式"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/secondary"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_thaw_mode"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="解冻模式"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/secondary"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_steam_mode"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="蒸汽模式"
                android:textColor="@color/text_primary"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/secondary"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/chip_group_power">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:text="加热时长"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_slider_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:40"
                        android:textColor="@color/secondary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stepSize="10"
                    android:value="40"
                    android:valueFrom="10"
                    android:valueTo="90"
                    app:thumbColor="@color/secondary"
                    app:tickVisible="false"
                    app:trackColorActive="@color/secondary"
                    app:trackColorInactive="#F5F5F5" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F5F5F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:text="加热温度"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_slider_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="200℃"
                        android:textColor="@color/secondary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_temp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stepSize="10"
                    android:value="90"
                    android:valueFrom="10"
                    android:valueTo="300"
                    app:thumbColor="@color/secondary"
                    app:tickVisible="false"
                    app:trackColorActive="@color/secondary"
                    app:trackColorInactive="#F5F5F5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_microwave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            android:text="开始加热"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/secondary"
            app:cornerRadius="30dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_controls" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>