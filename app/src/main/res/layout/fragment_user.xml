<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.agonylua.smarthome.viewModel.UserViewModel" />
        <variable
            name="user"
            type="com.agonylua.smarthome.model.User" />

        <!-- 可以通过导入 View 控制不同登录状态下的 UI 显示 -->
        <import type="android.view.View" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F6F8"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp">

            <!-- 顶部用户资料卡片 (Hero Card) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_user_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#1F2937"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/UserAvatarStyle"
                        app:layout_constraintDimensionRatio="1:1" />

                    <!-- DataBinding: 动态绑定用户名，为空时显示未登录 -->
                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text='@{user.nickname == null ? user.username : user.nickname}'
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- DataBinding: 动态绑定用户角色 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text='@{user.userId.equals("000000") ? "管理员" : "普通用户"}'
                        android:textColor="#14B8A6"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 设置项分组卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/card_user_profile"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/bt_user_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:background="@drawable/background_round_corner"
                        android:drawablePadding="6dp"
                        android:padding="6dp"
                        android:text="个人资料"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="normal"
                        app:drawableEndCompat="@drawable/ic_arrow_right"
                        app:drawableStartCompat="@drawable/ic_user_info"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/bt_home_manager"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/background_round_corner"
                        android:drawablePadding="6dp"
                        android:padding="6dp"
                        android:text="家庭管理"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="normal"
                        app:drawableEndCompat="@drawable/ic_arrow_right"
                        app:drawableStartCompat="@drawable/ic_home_settings"
                        app:layout_constraintTop_toBottomOf="@id/bt_user_info" />

                    <TextView
                        android:id="@+id/bt_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/background_round_corner"
                        android:drawablePadding="6dp"
                        android:padding="6dp"
                        android:text="语言设置"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="normal"
                        app:drawableEndCompat="@drawable/ic_arrow_right"
                        app:drawableStartCompat="@drawable/ic_gateway"
                        app:layout_constraintTop_toBottomOf="@id/bt_home_manager"
                        tools:layout_editor_absoluteX="16dp" />

                    <TextView
                        android:id="@+id/bt_about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/background_round_corner"
                        android:drawablePadding="6dp"
                        android:padding="6dp"
                        android:text="关于"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="normal"
                        app:drawableEndCompat="@drawable/ic_arrow_right"
                        app:drawableStartCompat="@drawable/ic_info"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/bt_language" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 退出登录按钮 (危险操作区) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:onClick="@{() -> viewModel.logout()}"
                android:text="退出登录"
                android:textColor="#EF4444"
                android:textSize="16sp"
                app:backgroundTint="#FEE2E2"
                app:cornerRadius="16dp"
                app:elevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>