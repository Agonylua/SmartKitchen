<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.agonylua.smartKitchen.viewModel.MonitorViewModel" />

        <variable
            name="hasRunningDevice"
            type="boolean" />
    </data>

    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/refreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FAFAFA"> <!-- 更柔和的纯白灰底色 -->

        <com.scwang.smart.refresh.header.ClassicsHeader
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:srlAccentColor="#9E9E9E"
            app:srlPrimaryColor="#FAFAFA" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F4F6F8"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="48dp">

                <TextView
                    android:id="@+id/tv_header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:text="数据监控"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_header_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="4dp"
                    android:text="设备实时数据分析"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_header_title" />

                <!-- 核心视觉区：Hero Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_hero_running"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="#1F2937"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_header_subtitle"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp">

                        <TextView
                            android:id="@+id/tv_hero_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="当前正在运行的设备"
                            android:textColor="#9CA3AF"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- 动态绑定呼吸灯 -->
                        <View
                            android:id="@+id/view_active_indicator"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/circle_progress_teal"
                            app:isBreathing="@{viewModel.onlineCount > 0}"
                            app:layout_constraintBottom_toBottomOf="@id/tv_hero_label"
                            app:layout_constraintStart_toEndOf="@id/tv_hero_label"
                            app:layout_constraintTop_toTopOf="@id/tv_hero_label" />

                        <!-- 动态绑定数量 -->
                        <TextView
                            android:id="@+id/tv_running_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@{viewModel.onlineCount.toString()}"
                            android:textColor="#FFFFFF"
                            android:textSize="56sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_hero_label" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="12dp"
                            android:text="台"
                            android:textColor="#D1D5DB"
                            android:textSize="18sp"
                            app:layout_constraintBottom_toBottomOf="@id/tv_running_count"
                            app:layout_constraintStart_toEndOf="@id/tv_running_count" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 用电趋势图表区 -->
                <TextView
                    android:id="@+id/tv_chart_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:text="近7日能耗趋势 (kWh)"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_hero_running" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_chart_power"
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_chart_title"
                    app:strokeWidth="0dp">

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/line_chart_power"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_device_info_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:text="正在运行的设备详情"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_chart_power" />

                <!-- 使用 DataBinding 控制显隐，并利用 adapter 自动提交 List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_running_devices"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="@{hasRunningDevice ? View.VISIBLE : View.GONE}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_device_info_title"
                    app:runningDeviceList="@{viewModel.onlineDevices}"
                    tools:listitem="@layout/item_monitor_card" />

                <!-- 无设备时的空状态提示，反向判断可见性 -->
                <TextView
                    android:id="@+id/tv_empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="当前没有设备运行"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:visibility="@{hasRunningDevice ? View.GONE : View.VISIBLE}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_device_info_title" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </com.scwang.smart.refresh.layout.SmartRefreshLayout>
</layout>