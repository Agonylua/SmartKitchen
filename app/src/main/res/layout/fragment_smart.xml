<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <!-- DataBinding placeholder -->
    </data>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F6F8"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp">
            <!-- 顶部大标题 -->
            <TextView
                android:id="@+id/tv_smart_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="@string/smart_header"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <!-- 第 1 部分：一键执行 (横向滑动) -->
            <TextView
                android:id="@+id/tv_tap_to_run_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="@string/tap_to_run_title"
                android:textColor="#374151"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_smart_header" />
            <HorizontalScrollView
                android:id="@+id/hsv_tap_to_run"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tv_tap_to_run_title">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- 场景卡片 1：一键烹饪 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="100dp"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="#1F2937"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/emoji_cooking"
                                android:textSize="24sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/cooking_mode"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- 场景卡片 2：离家关闭 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="100dp"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/emoji_leaving"
                                android:textSize="24sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/leaving_mode"
                                android:textColor="#111827"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>
            <!-- 第 2 部分：自动触发规则 -->
            <TextView
                android:id="@+id/tv_automation_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="@string/automation_title"
                android:textColor="#374151"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/hsv_tap_to_run" />
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_add_rule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                app:backgroundTint="#14B8A6"
                app:fabSize="mini"
                app:layout_constraintBottom_toBottomOf="@id/tv_automation_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tv_automation_title"
                app:srcCompat="@drawable/ic_add"
                app:tint="#FFFFFF" />
            <!-- 这里先放置一个硬编码的自动化卡片展示样式 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_auto_rule_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_automation_title"
                app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <TextView
                        android:id="@+id/tv_rule_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/high_temp_vent"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/switch_rule"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_rule"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:layout_constraintBottom_toBottomOf="@id/tv_rule_name"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tv_rule_name" />
                    <View
                        android:id="@+id/divider_rule"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#F3F4F6"
                        app:layout_constraintTop_toBottomOf="@id/tv_rule_name" />
                    <!-- IF 条件 -->
                    <TextView
                        android:id="@+id/tv_if_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_circle_outline_faint"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="IF"
                        android:textColor="#3B82F6"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider_rule" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/condition_high_temp"
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@id/tv_if_label"
                        app:layout_constraintStart_toEndOf="@id/tv_if_label"
                        app:layout_constraintTop_toTopOf="@id/tv_if_label" />
                    <!-- THEN 动作 -->
                    <TextView
                        android:id="@+id/tv_then_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_circle_outline_faint"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="THEN"
                        android:textColor="#14B8A6"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_if_label" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/action_turn_on_fan"
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@id/tv_then_label"
                        app:layout_constraintStart_toEndOf="@id/tv_then_label"
                        app:layout_constraintTop_toTopOf="@id/tv_then_label" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>