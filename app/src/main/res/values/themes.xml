<resources>

    <style name="Theme.SmartHome" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/brand_orange</item>
        <item name="colorSecondaryVariant">@color/brand_orange</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/bg_page_light</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="android:statusBarColor">@color/bg_page_light</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button.UnelevatedButton
        </item>
    </style>
</resources>